<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">

    <title>
      {{ page_title }}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700&family=Lustria&display=swap"
      rel="stylesheet"
    >

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
      };
    </script>
    <style>
      /* Match Dawn rem scale so Figma px values (70 → 7rem, 20 → 2rem) stay correct */
      html {
        font-size: 62.5%;
        -webkit-text-size-adjust: 100%;
      }

      body.gift-guide-page {
        margin: 0;
        font-size: 1.6rem;
        -webkit-font-smoothing: antialiased;
      }
    </style>
  </head>

  <body class="gift-guide-page">
    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>
  </body>
</html>
